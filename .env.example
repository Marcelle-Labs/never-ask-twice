# Default 5433 to avoid collision with common local Postgres on 5432
DATABASE_URL=postgresql://neverasktwice:neverasktwice@localhost:5433/neverasktwice

# Alibaba Cloud DashScope — get key at https://dashscope.aliyun.com
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# e.g. qwen-turbo / qwen-plus / qwen-max
QWEN_CHAT_MODEL=

QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_EMBEDDING_DIM=1024

# Max tokens injected into context per agent turn
MEMORY_TOKEN_BUDGET=1200

LINEAR_API_KEY=lin_api_...