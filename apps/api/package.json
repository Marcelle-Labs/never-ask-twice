{
  "name": "@never-ask-twice/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hono API for Never Ask Twice — Enterprise Support MemoryAgent on Qwen Cloud.",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-api-assets.mjs",
    "dev": "tsx --env-file=../../.env --watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "openai": "^4.104.0",
    "pg": "^8.22.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
